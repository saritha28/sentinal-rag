# SentinelRAG environment variables (local development)
# Copy this file to `.env` and fill in real values.
# In production, secrets come from External Secrets Operator + AWS Secrets Manager / GCP Secret Manager.

# --- Environment ---
ENVIRONMENT=local
LOG_LEVEL=INFO
API_BASE_PATH=/api/v1

# --- Database (Postgres + pgvector) ---
DATABASE_URL=postgresql+asyncpg://sentinel:sentinel@localhost:5432/sentinelrag
DATABASE_URL_SYNC=postgresql://sentinel:sentinel@localhost:5432/sentinelrag

# --- Cache ---
# Host port 6380 (container port 6379) to avoid conflicts with native Redis on the host.
REDIS_URL=redis://localhost:6380/0

# --- Object storage (MinIO local; S3/GCS in cloud) ---
OBJECT_STORAGE_PROVIDER=minio
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=minioadmin
OBJECT_STORAGE_BUCKET_DOCUMENTS=sentinelrag-documents
OBJECT_STORAGE_BUCKET_AUDIT=sentinelrag-audit
OBJECT_STORAGE_REGION=us-east-1

# --- Auth (Keycloak) ---
KEYCLOAK_ISSUER_URL=http://localhost:8080/realms/sentinelrag
KEYCLOAK_AUDIENCE=sentinelrag-api
KEYCLOAK_JWKS_URL=http://localhost:8080/realms/sentinelrag/protocol/openid-connect/certs
JWT_ALGORITHM=RS256

# --- LLM providers ---
# Ollama is the default; cloud providers are opt-in per request.
LLM_DEFAULT_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_GENERATION_MODEL=ollama/llama3.1:8b
DEFAULT_EMBEDDING_MODEL=ollama/nomic-embed-text
DEFAULT_RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# Cloud provider API keys (only used when tenant opts in via permission).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
COHERE_API_KEY=

# --- Temporal ---
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE_INGESTION=ingestion
TEMPORAL_TASK_QUEUE_EVALUATION=evaluation

# --- Feature flags (Unleash) ---
UNLEASH_URL=http://localhost:4242/api/
UNLEASH_API_TOKEN=default:development.unleash-insecure-api-token
UNLEASH_APP_NAME=sentinelrag-dev

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=sentinelrag-api
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=local

# --- Retrieval defaults ---
RETRIEVAL_MODE=hybrid
RETRIEVAL_TOP_K_BM25=20
RETRIEVAL_TOP_K_VECTOR=20
RETRIEVAL_TOP_K_RERANK=8

# --- Cost / budget ---
ENABLE_COST_TRACKING=true
DEFAULT_TENANT_MONTHLY_BUDGET_USD=50

# --- Audit ---
ENABLE_AUDIT_LOGGING=true
AUDIT_S3_OBJECT_LOCK=false  # set true in cloud envs

# --- Frontend (when running locally) ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-me-with-openssl-rand-base64-32
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
KEYCLOAK_CLIENT_ID=sentinelrag-frontend
KEYCLOAK_CLIENT_SECRET=
