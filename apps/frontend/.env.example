# Frontend environment.
# Copy to .env.local for local development.

# Backend API base URL — Next.js proxies /api/* to this in dev.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Auth token for local dev. In cloud, NextAuth.js handles this through
# Keycloak. The dev token short-circuit is gated by AUTH_ALLOW_DEV_TOKEN
# on the backend (see CLAUDE.md "Local dev: skipping Keycloak").
NEXT_PUBLIC_DEV_TOKEN=dev

# NextAuth.js — used in cloud deploys.
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-me-with-openssl-rand-base64-32
KEYCLOAK_ISSUER=http://localhost:8080/realms/sentinelrag
KEYCLOAK_CLIENT_ID=sentinelrag-frontend
KEYCLOAK_CLIENT_SECRET=
