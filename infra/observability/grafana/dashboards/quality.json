{
  "title": "SentinelRAG — Answer Quality",
  "uid": "sentinelrag-quality",
  "schemaVersion": 39,
  "version": 1,
  "tags": ["sentinelrag", "quality", "rag"],
  "timezone": "browser",
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Grounding score distribution",
      "type": "histogram",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (le) (rate(sentinelrag_grounding_score_bucket[15m]))",
          "legendFormat": "groundedness",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "title": "Grounding p50 vs p95 (rolling 1h)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(sentinelrag_grounding_score_bucket[15m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(sentinelrag_grounding_score_bucket[15m])))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "id": 3,
      "title": "Abstention vs total",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(sentinelrag_queries_total{status=\"abstained\"}[5m]))",
          "legendFormat": "abstained",
          "refId": "A"
        },
        {
          "expr": "sum(rate(sentinelrag_queries_total{status=\"completed\"}[5m]))",
          "legendFormat": "completed",
          "refId": "B"
        }
      ],
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 }
    }
  ]
}
